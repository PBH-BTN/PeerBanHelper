    "@types/node": "^25.6.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "husky": "^9.1.7",
    "less": "^4.6.4",
    "lint-staged": "^17.0.2",
    "npm-run-all2": "^9.0.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.66.0",
