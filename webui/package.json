  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "_ai_agent_hint": "This project using pnpm's patch feature so you MUST use pnpm, not npm or yarn. If pnpm not installed, you MUST install it first.",
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,vue}": [
